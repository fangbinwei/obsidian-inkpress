{
  "name": "obsidian-inkpress",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write",
    "lint": "biome lint",
    "check": "biome check --write",
    "check:ci": "biome ci",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "release:patch": "pnpm version patch && git push --follow-tags",
    "release:minor": "pnpm version minor && git push --follow-tags",
    "release:major": "pnpm version major && git push --follow-tags"
  },
  "dependencies": {
    "ali-oss": "^6.20.0",
    "inkpress-renderer": "^0.2.0",
    "proxy-agent": "^8.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/ali-oss": "^6.23.3",
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.5.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
